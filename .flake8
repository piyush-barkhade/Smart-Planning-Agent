[flake8]
max-line-length = 100
exclude = 
    .git,
    __pycache__,
    venv,
    env,
    .venv,
    .env,
    node_modules,
    .eggs,
    *.egg-info,
    build,
    dist

ignore = 
    E203,
    E266,
    E501,
    W503,
    W504,
    F403,
    F401

per-file-ignores =
    __init__.py:F401
    tests/*:F841,F401

# Complexity thresholds
max-complexity = 10
